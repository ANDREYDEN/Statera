{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2022",
    "noImplicitReturns": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "compileOnSave": true,
  "include": [
    "src",
    "tests",
    "index.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}